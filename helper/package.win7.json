{
  "name": "remote-support-helper",
  "_comment": "Windows 7/8/8.1 variant — same source as package.json, pinned to Electron 22 (the last version supporting these OS versions; Electron 23+ requires Windows 10+). Do not bump the electron version here without re-verifying Win7 compatibility. See scripts/build-win7-package.js for how this is swapped in during CI.",
  "version": "1.1.25",
  "description": "Customer helper app for Remote Support (Windows 7/8/8.1 build)",
  "author": "ServiceLC",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "build:win": "electron-builder --win nsis",
    "build:mac": "electron-builder --mac dmg",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@jitsi/robotjs": "^0.6.24",
    "form-data": "^4.0.0",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "node-abi": "^4.26.0",
    "prebuild-install": "^7.1.3"
  },
  "build": {
    "productName": "Remote Support Helper",
    "appId": "com.servicelc.remotesupport.helper",
    "directories": {
      "buildResources": "build-resources"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build-resources/icon.ico",
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build-resources/icon.png"
    },
    "dmg": {
      "window": {
        "width": 540,
        "height": 420
      },
      "contents": [
        {
          "x": 130,
          "y": 180,
          "type": "file"
        },
        {
          "x": 410,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 270,
          "y": 330,
          "type": "file",
          "path": "dmg-resources/Fix and Open Helper.command"
        }
      ]
    },
    "npmRebuild": true
  }
}
