{
  "name": "remote-support-helper",
  "version": "1.1.15",
  "description": "Customer helper app for Remote Support",
  "author": "ServiceLC",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "build:win": "electron-builder --win nsis",
    "build:mac": "electron-builder --mac dmg",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "form-data": "^4.0.0",
    "robotjs": "^0.7.1",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "node-abi": "^4.26.0",
    "prebuild-install": "^7.1.3"
  },
  "build": {
    "productName": "Remote Support Helper",
    "appId": "com.servicelc.remotesupport.helper",
    "directories": {
      "buildResources": "build-resources"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build-resources/icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build-resources/icon.png"
    },
    "dmg": {
      "window": {
        "width": 540,
        "height": 420
      },
      "contents": [
        {
          "x": 130,
          "y": 180,
          "type": "file"
        },
        {
          "x": 410,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 270,
          "y": 330,
          "type": "file",
          "path": "dmg-resources/Fix and Open Helper.command"
        }
      ]
    },
    "npmRebuild": true
  }
}
